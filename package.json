{
  "private": true,
  "name": "blog",
  "description": "A blog engine with remix.run",
  "license": "MIT",
  "scripts": {
    "push:db": "prisma db push",
    "prisma": "prisma studio",
    "migrate": "prisma migrate dev --name init",
    "build": "tailwindcss -i ./src/styles/index.css -o ./src/styles/dist.css -m && remix build; cp -r ./posts ./api; cp -r posts api/_build",
    "css": "tailwindcss -i ./src/styles/index.css -o ./src/styles/dist.css --watch",
    "config-json": "node config-builder",
    "predev": "npm run config-json",
    "prebuild": "npm run config-json",
    "dev": "concurrently 'yarn css' 'remix dev'",
    "postinstall": "remix setup node",
    "start": "remix-serve api/_build"
  },
  "dependencies": {
    "@codemirror/autocomplete": "0.19.12",
    "@codemirror/closebrackets": "0.19.0",
    "@codemirror/commands": "0.19.8",
    "@codemirror/comment": "0.19.0",
    "@codemirror/fold": "0.19.3",
    "@codemirror/history": "0.19.2",
    "@codemirror/lang-json": "0.19.1",
    "@codemirror/lang-markdown": "0.19.6",
    "@codemirror/lang-sql": "0.19.4",
    "@codemirror/language": "0.19.7",
    "@codemirror/lint": "0.19.3",
    "@codemirror/matchbrackets": "0.19.4",
    "@codemirror/rangeset": "0.19.6",
    "@codemirror/search": "0.19.6",
    "@codemirror/state": "0.19.6",
    "@codemirror/text": "0.19.6",
    "@codemirror/view": "0.19.42",
    "@prisma/client": "3.8.1",
    "@radix-ui/react-switch": "0.1.4",
    "@remix-run/react": "1.1.3",
    "@remix-run/serve": "1.1.3",
    "@remix-run/vercel": "1.1.3",
    "@tailwindcss/forms": "0.4.0",
    "add": "2.0.6",
    "dotenv": "15.0.0",
    "postcss": "8.4.5",
    "prisma": "3.8.1",
    "react": "17.0.2",
    "react-collapse": "^5.1.1",
    "react-dom": "17.0.2",
    "react-icons": "4.3.1",
    "react-markdown": "8.0.0",
    "react-syntax-highlighter": "15.4.5",
    "rehype-document": "6.0.1",
    "rehype-parse": "8.0.4",
    "rehype-react": "7.0.4",
    "rehype-stringify": "9.0.3",
    "remark-breaks": "3.0.2",
    "remark-gfm": "3.0.1",
    "remark-parse": "10.0.1",
    "remark-rehype": "10.1.0",
    "remix": "1.1.3",
    "remix-auth": "3.2.1",
    "remix-auth-github": "1.0.0",
    "unified": "10.1.1"
  },
  "devDependencies": {
    "@remix-run/dev": "1.1.3",
    "@tailwindcss/typography": "0.5.0",
    "@types/node": "17.0.11",
    "@types/react": "17.0.24",
    "@types/react-collapse": "5.0.1",
    "@types/react-dom": "17.0.9",
    "@types/react-syntax-highlighter": "13.5.2",
    "concurrently": "7.0.0",
    "tailwindcss": "3.0.16",
    "ts-node": "10.4.0",
    "typescript": "4.5.5"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": true
}
